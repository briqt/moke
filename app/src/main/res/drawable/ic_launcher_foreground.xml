<?xml version="1.0" encoding="utf-8"?>
<!-- Moke 图标前景：双色书法 M（左墨玉 / 右墨白）。笔脚微外撇、笔画收圆、去中缝墨滴。
     viewport 1024，M 落在自适应图标安全区内。 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">
    <!-- M 左半（墨玉，主色强调——较主题绿更浓） -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#3AD9A8"
        android:strokeWidth="100"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M327,694 L369,344 L512,551" />
    <!-- M 右半（墨白） -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#EAF1F6"
        android:strokeWidth="100"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M512,551 L655,344 L697,694" />
</vector>
